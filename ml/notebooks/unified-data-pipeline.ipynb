    "\n",
    "    return processed_count, processed_frames\n",
    "    \n",
    "def create_train_val_test_splits(all_frames, output_dir, train_ratio=0.7, val_ratio=0.15, test_ratio=0.15):\n",
    "    \"\"\"\n",
    "    Create train/val/test splits from the combined annotation frames\n",
    "    \n",
    "    Args:\n",
    "        all_frames (dict): Dictionary of all processed frames\n",
    "        output_dir (str): Directory to save splits\n",
    "        train_ratio (float): Ratio for training set\n",
    "        val_ratio (float): Ratio for validation set\n",
    "        test_ratio (float): Ratio for test set\n",
    "        \n",
    "    Returns:\n",
    "        dict: Split counts statistics\n",
    "    \"\"\"\n",
    "    # Normalize emotion labels according to the mapping\n",
    "    EMOTION_MAPPING = {\n",
    "        \"Happy or Playful\": \"Happy/Playful\",\n",
    "        \"Relaxed\": \"Relaxed\",\n",
    "        \"Submissive\": \"Submissive/Appeasement\",\n",
    "        \"Excited\": \"Happy/Playful\",\n",
    "        \"Drowsy or Bored\": \"Relaxed\",\n",
    "        \"Curious or Confused\": \"Curiosity/Alertness\",\n",
    "        \"Confident or Alert\": \"Curiosity/Alertness\",\n",
    "        \"Jealous\": \"Stressed\",\n",
    "        \"Stressed\": \"Stressed\",\n",
    "        \"Frustrated\": \"Stressed\",\n",
    "        \"Unsure or Uneasy\": \"Fearful/Anxious\",\n",
    "        \"Possessive, Territorial, Dominant\": \"Aggressive/Threatening\",\n",
    "        \"Fear or Aggression\": \"Fearful/Anxious\",\n",
    "        \"Pain\": \"Stressed\"\n",
    "    }\n",
    "    \n",
    "    # Ensure ratios sum to 1\n",
    "    total = train_ratio + val_ratio + test_ratio\n",
    "    train_ratio = train_ratio / total\n",
    "    val_ratio = val_ratio / total\n",
    "    test_ratio = test_ratio / total\n",
    "    \n",
    "    # Normalize emotion labels in the data\n",
    "    normalized_frames = {}\n",
    "    for filename, data in all_frames.items():\n",
    "        if \"emotions\" in data and \"primary_emotion\" in data[\"emotions\"]:\n",
    "            emotion = data[\"emotions\"][\"primary_emotion\"]\n",
    "            if emotion in EMOTION_MAPPING:\n",
    "                data[\"emotions\"][\"primary_emotion\"] = EMOTION_MAPPING[emotion]\n",
    "                data[\"emotions\"][\"original_emotion\"] = emotion  # Preserve original for reference\n",
    "            normalized_frames[filename] = data\n",
    "        else:\n",
    "            # Skip items without emotion data\n",
    "            print(f\"Warning: {filename} has no emotion data and will be skipped\")\n",
    "    \n",
    "    # Group by emotion\n",
    "    frames_by_emotion = {}\n",
    "    for filename, data in normalized_frames.items():\n",
    "        emotion = data[\"emotions\"][\"primary_emotion\"]\n",
    "        safe_emotion = emotion.replace(\"/\", \"_\").replace(\"\\\\\", \"_\")\n",
    "        if safe_emotion not in frames_by_emotion:\n",
    "            frames_by_emotion[safe_emotion] = []\n",
    "        frames_by_emotion[safe_emotion].append(filename)\n",
    "    \n",
    "    print(\"Emotion distribution after normalization:\")\n",
    "    for emotion, filenames in sorted(frames_by_emotion.items(), key=lambda x: len(x[1]), reverse=True):\n",
    "        print(f\"  {emotion}: {len(filenames)} frames\")\n",
    "    \n",
    "    # Split files for each emotion\n",
    "    train_files = []\n",
    "    val_files = []\n",
    "    test_files = []\n",
    "    \n",
    "    for emotion, filenames in frames_by_emotion.items():\n",
    "        import random\n",
    "        random.seed(42)  # For reproducibility\n",
    "        random.shuffle(filenames)\n",
    "        \n",
    "        n_files = len(filenames)\n",
    "        n_train = int(n_files * train_ratio)\n",
    "        n_val = int(n_files * val_ratio)\n",
    "        \n",
    "        train_files.extend(filenames[:n_train])\n",
    "        val_files.extend(filenames[n_train:n_train+n_val])\n",
    "        test_files.extend(filenames[n_train+n_val:])\n",
    "    \n",
    "    # Copy files to split directories\n",
    "    split_counts = {}\n",
    "    for emotion in frames_by_emotion.keys():\n",
    "        split_counts[emotion] = {\"train\": 0, \"validation\": 0, \"test\": 0}\n",
    "    \n",
    "    combined_frames_dir = os.path.join(output_dir, \"all_frames\")\n",
    "    \n",
    "    # Process each split\n",
    "    for file_list, split_dir, split_name in [\n",
    "        (train_files, os.path.join(output_dir, \"train_by_class\"), \"train\"),\n",
    "        (val_files, os.path.join(output_dir, \"val_by_class\"), \"validation\"),\n",
    "        (test_files, os.path.join(output_dir, \"test_by_class\"), \"test\")\n",
    "    ]:\n",
    "        print(f\"\\nCreating {split_name} split with {len(file_list)} files...\")\n",
    "        \n",
    "        for filename in tqdm(file_list, desc=f\"Processing {split_name} split\"):\n",
    "            data = normalized_frames[filename]\n",
    "            emotion = data[\"emotions\"][\"primary_emotion\"]\n",
    "            safe_emotion = emotion.replace(\"/\", \"_\").replace(\"\\\\\", \"_\")\n",
    "            \n",
    "            src_path = os.path.join(combined_frames_dir, filename)\n",
    "            dst_path = os.path.join(split_dir, safe_emotion, filename)\n",
    "            \n",
    "            if os.path.exists(src_path):\n",
    "                os.makedirs(os.path.dirname(dst_path), exist_ok=True)\n",
    "                shutil.copy2(src_path, dst_path)\n",
    "                split_counts[safe_emotion][split_name] += 1\n",
    "    \n",
    "    # Print split statistics\n",
    "    print(\"\\nSplit statistics:\")\n",
    "    total_counts = {\"train\": 0, \"validation\": 0, \"test\": 0}\n",
    "    \n",
    "    for emotion, counts in split_counts.items():\n",
    "        for split, count in counts.items():\n",
    "            total_counts[split] += count\n",
    "    \n",
    "    for split, total in total_counts.items():\n",
    "        print(f\"\\n{split.capitalize()} split:\")\n",
    "        print(f\"  Total: {total} images\")\n",
    "        print(\"  Emotion distribution:\")\n",
    "        for emotion, counts in split_counts.items():\n",
    "            count = counts[split]\n",
    "            if total > 0:\n",
    "                percent = count / total * 100\n",
    "                print(f\"    {emotion}: {count} ({percent:.1f}%)\")\n",
    "    \n",
    "    return split_counts\n",
    "\n",
    "def process_data():\n",
    "    \"\"\"Run the complete data processing pipeline\"\"\"\n",
    "    print(\"Starting Pawnder data processing pipeline...\")\n",
    "    \n",
    "    # Set random seed for reproducibility\n",
    "    random.seed(42)\n",
    "\n",
    "    # Define key paths\n",
    "    base_dir = project_root\n",
    "    videos_dir = os.path.join(DATA_DIRS['personal_dataset'], \"videos\")\n",
    "    personal_images_dir = os.path.join(DATA_DIRS['personal_dataset'], \"images\")\n",
    "    stanford_dir = DATA_DIRS['stanford_original']\n",
    "    stanford_images_dir = os.path.join(stanford_dir, \"Images\")\n",
    "    emotions_file = os.path.join(DATA_DIRS['interim'], \"emotions_only.json\")\n",
    "\n",
    "    # Output directories\n",
    "    output_dir = DATA_DIRS['processed']\n",
    "    combined_frames_dir = os.path.join(output_dir, \"all_frames\")\n",
    "    os.makedirs(combined_frames_dir, exist_ok=True)\n",
    "\n",
    "    # Create output directories\n",
    "    for split in [\"all_by_class\", \"train_by_class\", \"val_by_class\", \"test_by_class\"]:\n",
    "        split_dir = os.path.join(output_dir, split)\n",
    "        os.makedirs(split_dir, exist_ok=True)\n",
    "        for safe_name in SAFE_CLASS_NAMES:\n",
    "            os.makedirs(os.path.join(split_dir, safe_name), exist_ok=True)\n",
    "        os.makedirs(os.path.join(split_dir, \"unknown\"), exist_ok=True)"
   ]
